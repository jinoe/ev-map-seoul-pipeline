# 공공데이터포털에서 발급받은 서비스 키입니다.
# 권장: Encoding 키보다 Decoding 키를 넣어주세요.
DATA_GO_KR_SERVICE_KEY=870558a9a588993525361a99c310dcbc112b3a3ef8ed37225c632f57afe257a8

# 원격 MongoDB URI입니다.
# 예시 1: mongodb://user:password@your-server-ip:27017/ev_charger?authSource=admin
# 예시 2: mongodb+srv://user:password@cluster.example.mongodb.net/ev_charger
MONGODB_URI=mongodb://127.0.0.1:27017/ev_charger?authSource=admin
# MONGO_URI=mongodb://127.0.0.1:27017

# MongoDB DB 이름
MONGODB_DB_NAME=ev_charger

# 서울 zcode
SEOUL_ZCODE=11

# 공공데이터포털 API의 한 페이지 결과 수. 최대 9999.
NUM_OF_ROWS=9999

# 상태 조회 period. API 기준 최대 10분.
STATUS_PERIOD_MINUTES=10

# 스케줄러 실행 간격
SCHEDULER_INTERVAL_MINUTES=10

# run 실행 시 시작하자마자 기본정보도 새로 수집할지 여부
REFRESH_MASTER_ON_START=true
MASTER_DAILY_REFRESH_ENABLED=true
MASTER_REFRESH_HOUR_KST=4